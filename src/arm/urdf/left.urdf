    <origin xyz="-0.0047549 0.0060191 0.014132" rpy="-0.27968 -0.55633 -0.081982" />
    <parent link="finger1_link1" /><child link="finger1_link2" />
    <axis xyz="-1 0 0" /><limit lower="-0.1659" upper="0.9339" effort="0.6" velocity="11.1" />
  </joint>
  <link name="finger1_link3"><visual><geometry><mesh filename="package://arm/meshes/left/finger1_link3.STL"/></geometry></visual></link>
  <joint name="finger1_joint3" type="revolute">
    <origin xyz="0.0009915 -0.00026671 0.033166" rpy="-0.049049 0.017311 0.33774" />
    <parent link="finger1_link2" /><child link="finger1_link3" />
    <axis xyz="0 1 0" /><limit lower="-0.4932" upper="1.6272" effort="0.3" velocity="12.86" />
  </joint>
  <link name="finger1_link4"><visual><geometry><mesh filename="package://arm/meshes/left/finger1_link4.STL"/></geometry></visual></link>
  <joint name="finger1_joint4" type="revolute">
    <origin xyz="0 4.0225E-05 0.028987" rpy="0 0 0" />
    <parent link="finger1_link3" /><child link="finger1_link4" />
    <axis xyz="0 1 0" /><limit lower="-0.4932" upper="1.6272" effort="0.3" velocity="13.57" />
  </joint>
  <link name="finger1_tip_link"><visual><geometry><mesh filename="package://arm/meshes/left/finger1_tip_link.STL"/></geometry></visual></link>
  <joint name="finger1_tip_fixed" type="fixed">
    <origin xyz="-0.001058 -0.00044022 0.029313" rpy="0 0 0" /><parent link="finger1_link4" /><child link="finger1_tip_link" />
  </joint>

  <!-- ======================= -->
