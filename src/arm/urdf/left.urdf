<?xml version="1.0" encoding="utf-8"?>
<robot name="left_robotic_arm_hand">

  <!-- ======================= -->
  <!-- ====   MATERIALS   ==== -->
  <!-- ======================= -->
  <material name="dark_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
  <material name="light_grey"><color rgba="0.8 0.8 0.8 1.0"/></material>
  <material name="yellow"><color rgba="1.0 0.85 0.1 1.0"/></material>
  <material name="red"><color rgba="0.9 0.2 0.2 1.0"/></material>

  <!-- ======================= -->
  <!-- ====   BASE & ARM  ==== -->
  <!-- ======================= -->
  
  <link name="base_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry><box size="0.1 0.1 0.01"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <visual>
      <origin xyz="0.0 0.0 0.25" rpy="0.0 0.0 0.0"/>
      <geometry><cylinder length="0.5" radius="0.01"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <visual>
      <origin xyz="0.0 0.0 0.5" rpy="0.0 0.0 0.0"/>
      <geometry><sphere radius="0.03"/></geometry>
      <material name="yellow"/>
    </visual>
  </link>

  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_pan_link"/>
    <origin xyz="0 0 0.5" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="1.0"/>
  </joint>
  <link name="shoulder_pan_link"/>

  <joint name="shoulder_tilt_joint" type="revolute">
    <parent link="shoulder_pan_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="0.94" effort="100" velocity="1.0"/>
  </joint>
  <link name="upper_arm_link">
    <visual>
        <geometry><cylinder length="0.2" radius="0.02"/></geometry>
        <origin xyz="0.1 0 0" rpy="0 1.57 0"/>
        <material name="light_grey"/>
    </visual>
    <visual>
        <geometry><sphere radius="0.02"/></geometry>
        <origin xyz="0.2 0 0" rpy="0 0 0"/>
        <material name="yellow"/>
    </visual>    
  </link>

  <joint name="elbow_flex_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="elbow_rot_link"/>
    <origin xyz="0.22 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0" upper="2.6" effort="100" velocity="1.0"/>
  </joint>
  <link name="elbow_rot_link"/>

  <joint name="elbow_rot_joint" type="revolute">
    <parent link="elbow_rot_link"/>
    <child link="forearm_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.57" upper="1.57" effort="50" velocity="1.5"/>
  </joint>
  <link name="forearm_link">
    <visual>
        <geometry><cylinder length="0.18" radius="0.02"/></geometry>
        <origin xyz="0.09 0 0" rpy="0 1.57 0"/>
        <material name="light_grey"/>
    </visual>
    <visual>
        <geometry><sphere radius="0.02"/></geometry>
        <origin xyz="0.18 0 0" rpy="0 0 0"/>
        <material name="yellow"/>
    </visual>    
  </link>

  <!-- WRIST FLEXION (Up/Down) -->
  <joint name="wrist_flex_joint" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_abd_link"/>
    <origin xyz="0.19 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="1.57" upper="4.71" effort="30" velocity="1.0"/>
  </joint>
  <link name="wrist_abd_link"/>

  <!-- WRIST ABDUCTION / PALM ATTACHMENT -->
  <joint name="wrist_abd_joint" type="revolute">
    <parent link="wrist_abd_link"/>
    <child link="palm_link"/>
    <origin xyz="0 0 0" rpy="0 -1.5708 0"/> 
    <axis xyz="0 0 1"/>
    <limit lower="-2.0" upper="2.0" effort="30" velocity="1.0"/>
  </joint>

  <!-- ======================= -->
  <!-- ====      PALM     ==== -->
  <!-- ======================= -->
  <link name="palm_link">
    <inertial>
      <origin xyz="-0.00292 -0.00042 0.03649" rpy="0 0 0" />
      <mass value="0.2179" />
      <inertia ixx="0.000185" ixy="-6.9e-07" ixz="6.8e-06" iyy="0.000122" iyz="1.2e-05" izz="8.3e-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://arm/meshes/left/palm_link.STL" /></geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <geometry><mesh filename="package://arm/meshes/left/palm_link.STL" /></geometry>
    </collision>
  </link>

  <!-- ======================= -->
  <!-- ====   FINGER 1    ==== -->
  <!-- ======================= -->
  <link name="finger1_link1"><visual><geometry><mesh filename="package://arm/meshes/left/finger1_link1.STL"/></geometry></visual></link>
  <joint name="finger1_joint1" type="revolute">
    <origin xyz="0.0085244 -0.020575 0.028712" rpy="1.328 -0.37161 0.7307" />
    <parent link="palm_link" /><child link="finger1_link1" />
    <axis xyz="0 1 0" /><limit lower="-0.0448" upper="1.6508" effort="0.6" velocity="8.58" />
  </joint>
  <link name="finger1_link2"><visual><geometry><mesh filename="package://arm/meshes/left/finger1_link2.STL"/></geometry></visual></link>
